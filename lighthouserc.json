{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "npm --workspace packages/storefront run preview",
      "startServerReadyPattern": "MiniOxygen is now running",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/collections/all",
        "http://localhost:3000/search?q=oil",
        "http://localhost:3000/pages/styleguide"
      ],
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", {"minScore": 0.85}],
        "categories:accessibility": ["error", {"minScore": 0.95}],
        "categories:best-practices": ["warn", {"minScore": 0.9}],
        "categories:seo": ["warn", {"minScore": 0.9}],
        "first-contentful-paint": ["warn", {"maxNumericValue": 1800}],
        "largest-contentful-paint": ["warn", {"maxNumericValue": 2500}],
        "cumulative-layout-shift": ["error", {"maxNumericValue": 0.1}],
        "interactive": ["warn", {"maxNumericValue": 3800}],
        "total-blocking-time": ["warn", {"maxNumericValue": 300}],
        "uses-text-compression": "error",
        "color-contrast": "error",
        "image-alt": "error",
        "label": "error",
        "html-has-lang": "error",
        "viewport": "error"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
